[Unit]
Description=AGFS Rust Server
After=network.target

[Service]
Type=simple
User=yalun
Group=yalun
WorkingDirectory=/home/yalun/Dev/agfs
ExecStart=/home/yalun/Dev/agfs/rust-src/target/release/agfs-server --config /home/yalun/Dev/agfs/test-config.yaml
ExecStop=/home/yalun/Dev/agfs/stop-agfs.sh
Restart=on-failure
RestartSec=5

# 环境变量
Environment=RUST_LOG=info

# 安全设置
NoNewPrivileges=true
PrivateTmp=true

[Install]
WantedBy=multi-user.target
